# --- Contact form (Resend) ---
RESEND_API_KEY=
CONTACT_TO_EMAIL=jaime@jrwcreative.group
CONTACT_FROM_EMAIL=

# --- Site URL (optional; falls back to https://jrwtech.works) ---
NEXT_PUBLIC_SITE_URL=

# --- Content CMS (/admin) ---
# Password the site owner uses to log in at /admin
ADMIN_PASSWORD=
# Random secret used to sign the admin session cookie (e.g. `openssl rand -base64 32`)
SESSION_SECRET=
# Provisioned automatically when you connect a Vercel Blob store to the project.
# Without it the site renders the built-in default copy and saves are disabled.
BLOB_READ_WRITE_TOKEN=
