# --- Contact form (Resend) ---
RESEND_API_KEY=
CONTACT_TO_EMAIL=jaime@jrwcreative.group
CONTACT_FROM_EMAIL=

# --- Site URL (optional; falls back to https://jrwtech.works) ---
NEXT_PUBLIC_SITE_URL=

# --- Content CMS (/admin) ---
# Initial password the site owner uses to log in at /admin. Once a new password
# is set from the admin UI (stored hashed as auth.json in CONTENT_DIR), that one
# is used instead. Recovery: delete auth.json from the volume to fall back here.
ADMIN_PASSWORD=
# Random secret used to sign the admin session cookie (e.g. `openssl rand -base64 32`)
SESSION_SECRET=
# Directory the CMS writes content.json and uploaded images (./uploads) to.
# Point this at a mounted PERSISTENT VOLUME (Coolify: Storages → mount path) so
# edits and uploaded logo/images survive redeploys. Defaults to <app>/data.
CONTENT_DIR=/app/data
