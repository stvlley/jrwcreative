# --- Contact form (Resend) ---
RESEND_API_KEY=
CONTACT_TO_EMAIL=jaime@jrwcreative.group
CONTACT_FROM_EMAIL=

# --- Site URL (optional; falls back to https://jrwtech.works) ---
NEXT_PUBLIC_SITE_URL=

# --- Content CMS (/admin) ---
# Password the site owner uses to log in at /admin
ADMIN_PASSWORD=
# Random secret used to sign the admin session cookie (e.g. `openssl rand -base64 32`)
SESSION_SECRET=
# Directory the CMS writes content.json to. Point this at a mounted PERSISTENT
# VOLUME (Coolify: Storages → mount path) so edits survive redeploys.
# Defaults to <app>/data if unset.
CONTENT_DIR=/app/data
